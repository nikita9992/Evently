  "components": {
    "schemas": {
      "CrearActividadDto": {
        "required": [
          "idCategoria",
          "precio",
          "titulo"
        ],
        "type": "object",
        "properties": {
          "idCategoria": {
            "type": "integer",
            "format": "int32"
          },
          "titulo": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string"
          },
          "descripcion": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "precio": {
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "fechaActiv": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "cupoMaximo": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CrearCategoriaDto": {
        "required": [
          "nombreCatego"
        ],
        "type": "object",
        "properties": {
          "nombreCatego": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "descripcion": {
            "maxLength": 255,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
