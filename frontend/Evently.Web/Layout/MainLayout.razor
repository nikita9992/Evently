@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToogleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">Evently</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart"
                       Color="Color.Inherit"
                       Href="/carrito" />
        <MudIconButton Icon="@Icons.Material.Filled.Person"
                       Color="Color.Inherit"
                       Href="/cuenta" />
    </MudAppBar>

    <MudDrawer @bind-Open="@drawerAbierto" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Menú</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Home">
                Inicio
            </MudNavLink>
            <MudNavLink Href="/actividades"
                        Icon="@Icons.Material.Filled.EventNote">
                Actividades
            </MudNavLink>
            <MudNavLink Href="/carrito"
                        Icon="@Icons.Material.Filled.ShoppingCart">
                Carrito
            </MudNavLink>
            <MudNavLink Href="/cuenta"
                        Icon="@Icons.Material.Filled.Person">
                Mi cuenta
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool drawerAbierto = false;

    private void ToogleDrawer()
    {
        drawerAbierto = !drawerAbierto;
    }
}