@page "/mispedidos"
@using Evently.Web.Models
@using Evently.Web.Services
@inject PedidoService PedidoService
@inject ClienteService ClienteService
@inject EstadoAuthService EstadoAuth
@inject NavigationManager Navegacion

<PageTitle>Mis pedidos — Evently</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="mr-2" />
        Mis pedidos
    </MudText>

    @if (estaCargando)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (!string.IsNullOrEmpty(errorMensaje))
    {
        <MudAlert Severity="Severity.Error">@errorMensaje</MudAlert>
    }
    else if (listaPedidos.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">
            No tienes pedidos realizados todavía.
        </MudAlert>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   Href="/actividades"
                   Class="mt-3"
                   StartIcon="@Icons.Material.Filled.EventNote">
            Ver actividades
        </MudButton>
    }
    else
    {
        @foreach (var pedido in listaPedidos)
        {
            <MudPaper Elevation="3" Class="pa-4 mb-4">
                <MudGrid>
                    <MudItem xs="12" sm="8">
                        <MudText Typo="Typo.h6">
                            Pedido #@pedido.IdPedido
                        </MudText>
                        <MudText Typo="Typo.body2" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday"
                                     Size="Size.Small" Class="mr-1" />
                            @pedido.FechaConfirm.ToString("dd/MM/yyyy HH:mm")
                        </MudText>
                    </MudItem>
                    <MudItem xs="12" sm="4" Class="d-flex justify-end align-center">
                        <MudChip T="string"
                                 Color="@(pedido.NombreEstado == "Confirmado"
                                                                      ? Color.Success : Color.Error)">
                    @pedido.NombreEstado
                </MudChip>
            </MudItem>
        </MudGrid>

                <MudDivider Class="my-2" />

        @foreach (var detalle in pedido.Detalles)
                {
                    <MudText Typo="Typo.body2" Class="mb-1">
                        • @detalle.TituloActividad —
                        @detalle.Cantidad ud. x @detalle.PrecioUnitario.ToString("C")
                        = <strong>@detalle.ImporteLinea.ToString("C")</strong>
                    </MudText>
                }

                <MudDivider Class="my-2" />

                <MudText Typo="Typo.subtitle1" Align="Align.Right">
                    Total: <strong>
                        @(pedido.Detalles.Sum(d => d.ImporteLinea).ToString("C"))
                    </strong>
                </MudText>
            </MudPaper>
        }
    }
</MudContainer>

@code {
    private List<PedidoDto> listaPedidos = new();
    private string errorMensaje = string.Empty;
    private bool estaCargando = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Cargar token si no está cargado
            if (!EstadoAuth.EstaAutenticado)
            {
                await EstadoAuth.CargarDesdeLocalStorageAsync();
                StateHasChanged();
            }

            // Redirigir si no está autenticado
            if (!EstadoAuth.EstaAutenticado)
            {
                Navegacion.NavigateTo("/login");
                return;
            }

            // Obtener el cliente del usuario
            var cliente = await ClienteService.ObtenerPorUsuarioAsync(
                EstadoAuth.IdUsuario, EstadoAuth.Token);

            if (cliente == null)
            {
                errorMensaje = "No tienes datos personales registrados. " +
                               "Completa tu perfil primero.";
                estaCargando = false;
                StateHasChanged();
                return;
            }

            // Cargar pedidos del cliente
            listaPedidos = await PedidoService.ObtenerPorClienteAsync(
                cliente.IdCliente, EstadoAuth.Token);

            estaCargando = false;
            StateHasChanged();
        }
    }
}