@page "/carrito"
@using Evently.Web.Models
@using Evently.Web.Services
@inject PedidoService PedidoService
@inject ClienteService ClienteService
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject EstadoAuthService EstadoAuth
@inject ISnackbar Snackbar

<PageTitle>Mi carrito — Evently</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Class="mr-2" />
        Mi carrito
    </MudText>

    @if (!string.IsNullOrEmpty(errorMensaje))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@errorMensaje</MudAlert>
    }

    @if (pedidoConfirmado)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4">
            ¡Pedido confirmado correctamente! Gracias por tu reserva.
        </MudAlert>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   Href="/mispedidos"
                   Class="mt-2">
            Ver mis pedidos
        </MudButton>
    }
    else if (elementosCarrito.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">
            No tienes actividades en el carrito.
        </MudAlert>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   Href="/actividades"
                   Class="mt-3"
                   StartIcon="@Icons.Material.Filled.EventNote">
            Ver actividades
        </MudButton>
    }
    else
    {
        <MudTable Items="elementosCarrito" Hover="true" Elevation="3" Class="mb-4">
            <HeaderContent>
                <MudTh>Actividad</MudTh>
                <MudTh>Precio</MudTh>
                <MudTh>Cantidad</MudTh>
                <MudTh>Importe</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Titulo</MudTd>
                <MudTd>@context.Precio.ToString("C")</MudTd>
                <MudTd>@context.Cantidad</MudTd>
                <MudTd>@context.ImporteLinea.ToString("C")</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@(() => EliminarDelCarrito(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>

        <MudText Typo="Typo.h6" Class="mb-4">
            Total: @elementosCarrito.Sum(e => e.ImporteLinea).ToString("C")
        </MudText>

        @if (!EstadoAuth.EstaAutenticado)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-3">
                Debes iniciar sesión para confirmar el pedido.
            </MudAlert>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Href="/login"
                       StartIcon="@Icons.Material.Filled.Login">
                Iniciar sesión
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       OnClick="ConfirmarPedido"
                       Disabled="estaConfirmando"
                       StartIcon="@Icons.Material.Filled.CheckCircle">
                @if (estaConfirmando)
                {
                    <MudProgressCircular Size="Size.Small"
                                         Indeterminate="true"
                                         Class="mr-2" />
                }
                Confirmar pedido
            </MudButton>
        }
    }
</MudContainer>

@code {
    private List<ItemCarrito> elementosCarrito = new();
    private string errorMensaje = string.Empty;
    private bool estaConfirmando = false;
    private bool pedidoConfirmado = false;
    private int idCliente = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!EstadoAuth.EstaAutenticado)
            {
                await EstadoAuth.CargarDesdeLocalStorageAsync();
            }

            await CargarCarrito();

            if (EstadoAuth.EstaAutenticado)
            {
                var cliente = await ClienteService.ObtenerPorUsuarioAsync(
                    EstadoAuth.IdUsuario, EstadoAuth.Token);

                if (cliente != null)
                    idCliente = cliente.IdCliente;
            }

            StateHasChanged();
        }
    }

    private async Task CargarCarrito()
    {
        try
        {
            var json = await JS.InvokeAsync<string>(
                "obtenerCarrito", EstadoAuth.IdUsuario);

            if (!string.IsNullOrEmpty(json))
            {
                elementosCarrito = System.Text.Json.JsonSerializer
                    .Deserialize<List<ItemCarrito>>(json)
                    ?? new List<ItemCarrito>();
            }
        }
        catch
        {
            elementosCarrito = new List<ItemCarrito>();
        }
    }

    private async Task EliminarDelCarrito(ItemCarrito elemento)
    {
        elementosCarrito.Remove(elemento);
        await GuardarCarrito();
    }

    private async Task GuardarCarrito()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(elementosCarrito);
        await JS.InvokeVoidAsync("guardarCarrito", json, EstadoAuth.IdUsuario);
    }

    private async Task ConfirmarPedido()
    {
        estaConfirmando = true;
        errorMensaje = string.Empty;

        if (idCliente == 0)
        {
            errorMensaje = "Debes completar tus datos personales antes de confirmar un pedido.";
            estaConfirmando = false;
            return;
        }

        var dto = new ConfirmarPedidoDto
        {
            IdCliente = idCliente,
            Actividades = elementosCarrito.Select(e => new ItemCarritoDto
            {
                IdActividad = e.IdActividad,
                Cantidad = e.Cantidad,
                PrecioUnitario = e.Precio
            }).ToList()
        };

        var resultado = await PedidoService.ConfirmarPedidoAsync(dto, EstadoAuth.Token);

        if (resultado == null)
        {
            errorMensaje = "No se ha podido confirmar el pedido. Inténtalo de nuevo.";
        }
        else
        {
            elementosCarrito.Clear();
            await JS.InvokeVoidAsync("limpiarCarrito", EstadoAuth.IdUsuario);
            pedidoConfirmado = true;
            Snackbar.Add("¡Pedido confirmado correctamente!", Severity.Success);
        }

        estaConfirmando = false;
    }
}