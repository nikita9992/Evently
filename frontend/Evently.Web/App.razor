@inject EstadoAuthService EstadoAuth

<Router AppAssembly="typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>No encontrado</PageTitle>
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <MudText Typo="Typo.h5">Lo sentimos, esta página no existe.</MudText>
        </LayoutView>
    </NotFound>
</Router>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Cargar token del localStorage al iniciar la app
            await EstadoAuth.CargarDesdeLocalStorageAsync();
            StateHasChanged();
        }
    }
}